#!/bin/sh

echo "🔍 [pre-push] 배포 전 검증 시작..."

# 1. 린트
echo "  [1/3] 린트 검사..."
npm run lint 2>&1 | tail -3
if [ $? -ne 0 ]; then
  echo "❌ 린트 실패. push 중단."
  exit 1
fi

# 2. 타입 체크
echo "  [2/3] 타입 체크..."
npm run type-check 2>&1 | tail -5
if [ $? -ne 0 ]; then
  echo "❌ 타입 체크 실패. push 중단."
  exit 1
fi

# 3. 빌드 검증
echo "  [3/3] 프로덕션 빌드 검증..."
npm run build 2>&1 | tail -5
if [ $? -ne 0 ]; then
  echo "❌ 빌드 실패. push 중단."
  exit 1
fi

echo "✅ [pre-push] 린트+타입+빌드 모두 통과. push 진행."
