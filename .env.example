# Anthropic Claude API Key (필수 — 설정 페이지에서도 입력 가능)
ANTHROPIC_API_KEY=sk-ant-api03-...

# PostgreSQL 연결 URL (선택 — 없으면 localStorage만 사용)
DATABASE_URL=postgresql://user:password@host:5432/simulo

# 관리자 비밀번호 (선택)
ADMIN_PASSWORD=changeme

# 디자인 생성 프로바이더 (선택 — 기본값: rest-api)
# rest-api     → SVG 아티팩트 + Figma Variables API (현재)
# claude-design → Claude Design API (출시 후 교체)
DESIGN_PROVIDER=rest-api
