generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Analysis {
  id                    String   @id @default(uuid())
  createdAt             DateTime @default(now())
  hypothesis            String
  targetUser            String
  task                  String?
  projectTag            String?
  inputType             String   @default("image")
  mode                  String   @default("hypothesis")
  analysisOptions       Json?
  verdict               String
  score                 Int
  taskSuccessLikelihood String?
  taskSuccessReason     String?
  summary               String
  strengths             String[]
  thinkAloud            Json?
  issues                Json?
  thumbnailUrls         String[]
  scoreBreakdown        Json?
  verdictReason         String?
  flowAnalysis          Json?
  flowSteps             Json?
  isComparison          Boolean  @default(false)
  comparisonData        Json?
  previousAnalysisId    String?
  roundNumber           Int      @default(1)
  isImprovement         Boolean  @default(false)
}

model FlowAnalysis {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  hypothesis String
  targetUser String
  flowData   Json
  result     Json
  projectTag String?
}

model DashboardInsight {
  id         String   @id @default(uuid())
  period     String
  projectTag String?
  insights   Json
  createdAt  DateTime @default(now())
}
