{
  "name": "simulo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "dev:quick": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "type-check:e2e": "tsc --noEmit -p tsconfig.playwright.json",
    "test": "npx playwright test",
    "pretest": "npm run type-check:e2e",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed",
    "schema:validate": "npx tsx scripts/validateOutputSchemas.ts",
    "validate": "npm run lint && npm run type-check && npm run schema:validate && npm run build",
    "postinstall": "prisma generate",
    "db:check": "npx ts-node scripts/check-db.ts",
    "agent:idea": "npx tsx scripts/agents/idea-agent.ts",
    "agent:qa": "npx tsx scripts/agents/qa-agent.ts",
    "agent:notify": "npx tsx scripts/notifier/notify.ts",
    "agent:watcher": "npx tsx scripts/notifier/watcher.ts",
    "agent:install": "bash scripts/notifier/setup-watcher.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@prisma/client": "^6.19.3",
    "@types/sharp": "^0.31.1",
    "docx": "^9.6.1",
    "fluent-ffmpeg": "^2.1.3",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "multer": "^2.1.1",
    "next": "14.2.35",
    "prisma": "^6.19.3",
    "react": "^18",
    "react-dom": "^18",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/multer": "^2.1.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "eslint-plugin-unused-imports": "^4.4.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
